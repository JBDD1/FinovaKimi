<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Finova — Finanzas Personales</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="style.css">
</head>
<body data-theme="dark">
    <div id="sidebarOverlay" class="sidebar-overlay" onclick="toggleSidebar()"></div>
    <aside id="sidebar" class="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <span class="logo-icon">◆</span>
                <span class="logo-text">Finova</span>
            </div>
            <button class="sidebar-toggle" onclick="toggleSidebar()" title="Colapsar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 17l-5-5 5-5M18 17l-5-5 5-5"/></svg>
            </button>
        </div>
        <nav class="sidebar-nav">
            <a href="#" class="nav-item active" data-section="dashboard" onclick="navigateTo('dashboard')">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                <span>Dashboard</span>
            </a>
            <a href="#" class="nav-item" data-section="transactions" onclick="navigateTo('transactions')">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                <span>Ingresos & Gastos</span>
            </a>
            <div class="nav-group">
                <a href="#" class="nav-item" onclick="toggleInversionesGroup()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                    <span>Inversiones</span>
                    <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                </a>
                <div class="nav-submenu" id="inversionesSubmenu">
                    <a href="#" class="nav-subitem" data-section="portfolio" onclick="navigateTo('portfolio')">Cartera</a>
                    <a href="#" class="nav-subitem" data-section="watchlist" onclick="navigateTo('watchlist')">Watchlist</a>
                    <a href="#" class="nav-subitem" data-section="dividends" onclick="navigateTo('dividends')">Dividendos</a>
                </div>
            </div>
            <a href="#" class="nav-item" data-section="networth" onclick="navigateTo('networth')">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 000 4h4a2 2 0 010 4H8"/></svg>
                <span>Patrimonio Neto</span>
            </a>
            <a href="#" class="nav-item" data-section="alternatives" onclick="navigateTo('alternatives')">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                <span>Activos Alternativos</span>
            </a>
            <a href="#" class="nav-item" data-section="goals" onclick="navigateTo('goals')">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                <span>Objetivos</span>
            </a>
            <a href="#" class="nav-item" data-section="fiscal" onclick="navigateTo('fiscal')">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
                <span>Fiscalidad IRPF</span>
            </a>
            <a href="#" class="nav-item" data-section="simulator" onclick="navigateTo('simulator')">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20M4 4v16M20 4v16"/></svg>
                <span>Simulador</span>
            </a>
            <a href="#" class="nav-item" data-section="ai" onclick="navigateTo('ai')">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a2 2 0 012 2v2a2 2 0 01-2 2 2 2 0 01-2-2V4a2 2 0 012-2z"/><path d="M12 20a2 2 0 012 2v-2a2 2 0 01-2-2 2 2 0 01-2 2v2a2 2 0 012-2z"/><path d="M20 12a2 2 0 012-2h-2a2 2 0 01-2 2 2 2 0 012 2h2a2 2 0 01-2-2z"/><path d="M4 12a2 2 0 01-2 2h2a2 2 0 012-2 2 2 0 01-2-2H2a2 2 0 012 2z"/></svg>
                <span>Asesor IA</span>
            </a>
            <a href="#" class="nav-item" data-section="settings" onclick="navigateTo('settings')">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                <span>Ajustes</span>
            </a>
        </nav>
    </aside>
    <main id="mainContent" class="main-content">
        <header class="top-bar">
            <div class="top-bar-left">
                <button class="mobile-menu-btn" onclick="toggleSidebar()">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
                </button>
                <h1 id="pageTitle">Dashboard</h1>
            </div>
            <div class="top-bar-right">
                <button class="btn-icon" onclick="togglePrivacyMode()" title="Modo privacidad">
                    <svg id="privacyIcon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
                <button class="btn-icon" onclick="toggleTheme()" title="Cambiar tema">
                    <svg id="themeIcon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                </button>
            </div>
        </header>
        <div id="sectionsContainer" class="sections-container">
            <section id="dashboard" class="section active">
                <div class="kpi-grid">
                    <div class="kpi-card">
                        <div class="kpi-label">Patrimonio Total</div>
                        <div class="kpi-value" id="kpiPatrimonio">€0,00</div>
                        <div class="kpi-change" id="kpiPatrimonioChange">+0,00%</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-label">Inversiones</div>
                        <div class="kpi-value" id="kpiInversiones">€0,00</div>
                        <div class="kpi-change" id="kpiInversionesChange">+0,00%</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-label">Efectivo</div>
                        <div class="kpi-value" id="kpiEfectivo">€0,00</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-label">Deuda Neta</div>
                        <div class="kpi-value" id="kpiDeuda">€0,00</div>
                    </div>
                </div>
                <div class="dashboard-grid">
                    <div class="card chart-card">
                        <div class="card-header">
                            <h3>Evolución Patrimonio</h3>
                            <div class="chart-controls">
                                <button class="btn-sm active" onclick="setChartPeriod('6M')">6M</button>
                                <button class="btn-sm" onclick="setChartPeriod('1A')">1A</button>
                                <button class="btn-sm" onclick="setChartPeriod('TODO')">Todo</button>
                            </div>
                        </div>
                        <div class="chart-container"><canvas id="networthChart"></canvas></div>
                    </div>
                    <div class="card chart-card">
                        <div class="card-header"><h3>Distribución</h3></div>
                        <div class="chart-container donut-container"><canvas id="distributionChart"></canvas></div>
                    </div>
                    <div class="card">
                        <div class="card-header"><h3>Top Inversiones</h3></div>
                        <div id="topInvestments" class="top-investments"></div>
                    </div>
                    <div class="card">
                        <div class="card-header"><h3>Actividad Reciente</h3></div>
                        <div id="recentActivity" class="recent-activity"></div>
                    </div>
                </div>
            </section>
            <section id="transactions" class="section">
                <div class="section-toolbar">
                    <button class="btn-primary" onclick="openTransactionModal()">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                        Nueva Transacción
                    </button>
                    <div class="toolbar-filters">
                        <select id="txFilterType" onchange="filterTransactions()"><option value="all">Todos</option><option value="income">Ingresos</option><option value="expense">Gastos</option></select>
                        <select id="txFilterCategory" onchange="filterTransactions()"><option value="all">Todas categorías</option></select>
                        <input type="month" id="txFilterMonth" onchange="filterTransactions()">
                    </div>
                </div>
                <div class="card">
                    <div class="tx-summary">
                        <div class="tx-summary-item income"><span>Ingresos</span><strong id="txTotalIncome">€0,00</strong></div>
                        <div class="tx-summary-item expense"><span>Gastos</span><strong id="txTotalExpense">€0,00</strong></div>
                        <div class="tx-summary-item balance"><span>Balance</span><strong id="txBalance">€0,00</strong></div>
                    </div>
                    <div id="transactionsList" class="transactions-list"></div>
                </div>
                <div class="dashboard-grid two-col">
                    <div class="card chart-card">
                        <div class="card-header"><h3>Evolución Mensual</h3></div>
                        <div class="chart-container"><canvas id="txChart"></canvas></div>
                    </div>
                    <div class="card chart-card">
                        <div class="card-header"><h3>Gastos por Categoría</h3></div>
                        <div class="chart-container donut-container"><canvas id="expenseChart"></canvas></div>
                    </div>
                </div>
                <div class="card bizums-card">
                    <div class="card-header">
                        <h3>Bizums</h3>
                        <button class="btn-sm" onclick="openBizumModal()">+ Nuevo Bizum</button>
                    </div>
                    <div id="bizumsList" class="bizums-list"></div>
                </div>
            </section>
            <section id="portfolio" class="section">
                <div class="section-toolbar">
                    <div style="display:flex;gap:10px;align-items:center">
                        <button class="btn-primary" onclick="openInvestmentModal()">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                            Nueva Inversión
                        </button>
                        <button class="btn-refresh" id="refreshPricesBtn" onclick="manualRefreshPrices()">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6M1 20v-6h6M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
                            Actualizar precios
                        </button>
                    </div>
                </div>
                <div class="card"><div id="portfolioTable" class="portfolio-table"></div></div>
                <div class="dashboard-grid three-col">
                    <div class="card chart-card">
                        <div class="card-header"><h3>Concentración</h3></div>
                        <div class="chart-container donut-container"><canvas id="concentrationChart"></canvas></div>
                    </div>
                    <div class="card">
                        <div class="card-header"><h3>Correlación</h3></div>
                        <div id="correlationMatrix" class="correlation-matrix"></div>
                    </div>
                    <div class="card">
                        <div class="card-header"><h3>Tiempo en Cartera</h3></div>
                        <div id="holdingTime" class="holding-time"></div>
                    </div>
                </div>
            </section>
            <section id="watchlist" class="section">
                <div class="section-toolbar">
                    <div style="display:flex;gap:10px;align-items:center">
                        <button class="btn-primary" onclick="openWatchlistModal()">+ Añadir a Watchlist</button>
                        <button class="btn-refresh" id="refreshWatchlistBtn" onclick="manualRefreshWatchlist()">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6M1 20v-6h6M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
                            Actualizar
                        </button>
                    </div>
                </div>
                <div class="card"><div id="watchlistTable" class="watchlist-table"></div></div>
            </section>
            <section id="dividends" class="section">
                <div class="section-toolbar">
                    <button class="btn-primary" onclick="openDividendModal()">+ Registrar Dividendo</button>
                </div>
                <div class="dashboard-grid two-col">
                    <div class="card">
                        <div class="card-header"><h3>Dividendos Anuales</h3></div>
                        <div class="chart-container"><canvas id="dividendsChart"></canvas></div>
                    </div>
                    <div class="card">
                        <div class="card-header"><h3>Yield por Posición</h3></div>
                        <div id="yieldList" class="yield-list"></div>
                    </div>
                </div>
                <div class="card"><div id="dividendsList" class="dividends-list"></div></div>
            </section>
            <section id="networth" class="section">
                <div class="kpi-grid">
                    <div class="kpi-card"><div class="kpi-label">Efectivo</div><div class="kpi-value" id="nwCash">€0,00</div></div>
                    <div class="kpi-card"><div class="kpi-label">Inversiones</div><div class="kpi-value" id="nwInvestments">€0,00</div></div>
                    <div class="kpi-card"><div class="kpi-label">Alternativos</div><div class="kpi-value" id="nwAlternatives">€0,00</div></div>
                    <div class="kpi-card"><div class="kpi-label">Pasivos</div><div class="kpi-value" id="nwLiabilities">€0,00</div></div>
                </div>
                <div class="card">
                    <div class="card-header"><h3>Desglose por Categoría</h3></div>
                    <div id="networthBreakdown" class="networth-breakdown"></div>
                </div>
            </section>
            <section id="alternatives" class="section">
                <div class="section-toolbar">
                    <button class="btn-primary" onclick="openAlternativeModal()">+ Nuevo Activo</button>
                </div>
                <div id="alternativesGrid" class="alternatives-grid"></div>
            </section>
            <section id="goals" class="section">
                <div class="section-toolbar">
                    <button class="btn-primary" onclick="openGoalModal()">+ Nuevo Objetivo</button>
                </div>
                <div id="goalsList" class="goals-list"></div>
            </section>
            <section id="fiscal" class="section">
                <div class="fiscal-tabs">
                    <button class="fiscal-tab active" onclick="setFiscalTab('plusvalias')">Plusvalías</button>
                    <button class="fiscal-tab" onclick="setFiscalTab('dividendos')">Dividendos</button>
                    <button class="fiscal-tab" onclick="setFiscalTab('trabajo')">Rend. Trabajo</button>
                    <button class="fiscal-tab" onclick="setFiscalTab('minimos')">Mínimos</button>
                    <button class="fiscal-tab" onclick="setFiscalTab('resumen')">Resumen IRPF</button>
                </div>
                <div id="fiscalPlusvalias" class="fiscal-panel active">
                    <div class="dashboard-grid two-col">
                        <div class="card">
                            <div class="card-header"><h3>Ventas Realizadas</h3></div>
                            <div id="salesList" class="sales-list"></div>
                            <button class="btn-sm" onclick="openSaleModal()">+ Nueva Venta</button>
                        </div>
                        <div class="card">
                            <div class="card-header"><h3>Compensación Pérdidas</h3></div>
                            <div id="compensationInfo" class="compensation-info"></div>
                            <div class="form-group"><label>Plusvalías del ejercicio</label><input type="number" id="fiscalPlusvaliasEjercicio" class="form-input" value="0" step="0.01"></div>
                            <div class="form-group"><label>Minusvalías del ejercicio</label><input type="number" id="fiscalMinusvaliasEjercicio" class="form-input" value="0" step="0.01"></div>
                            <div class="form-group"><label>Minusvalías pendientes años anteriores</label><input type="number" id="fiscalMinusvaliasPendientes" class="form-input" value="0" step="0.01"></div>
                            <button class="btn-primary" onclick="calculateCompensation()">Calcular Compensación</button>
                            <div id="compensationResult" class="compensation-result"></div>
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-header"><h3>Simulador Impacto Fiscal Venta</h3></div>
                        <div class="simulator-form">
                            <div class="form-row">
                                <div class="form-group"><label>Valor de compra</label><input type="number" id="simBuyPrice" class="form-input" placeholder="0,00"></div>
                                <div class="form-group"><label>Valor de venta</label><input type="number" id="simSellPrice" class="form-input" placeholder="0,00"></div>
                                <div class="form-group"><label>Año compra</label><input type="number" id="simBuyYear" class="form-input" value="2023"></div>
                            </div>
                            <button class="btn-primary" onclick="simulateFiscalImpact()">Simular</button>
                            <div id="simFiscalResult" class="sim-result"></div>
                        </div>
                    </div>
                </div>
                <div id="fiscalDividendos" class="fiscal-panel">
                    <div class="card">
                        <div class="card-header"><h3>Dividendos Fiscales</h3></div>
                        <div id="fiscalDividendsList" class="fiscal-dividends-list"></div>
                        <div class="fiscal-summary">
                            <div class="fiscal-summary-row"><span>Total dividendos brutos</span><strong id="fiscalDivTotal">€0,00</strong></div>
                            <div class="fiscal-summary-row"><span>Retención 19%</span><strong id="fiscalDivRetencion">€0,00</strong></div>
                            <div class="fiscal-summary-row"><span>Neto percibido</span><strong id="fiscalDivNeto">€0,00</strong></div>
                        </div>
                    </div>
                </div>
                <div id="fiscalTrabajo" class="fiscal-panel">
                    <div class="card">
                        <div class="card-header"><h3>Rendimientos del Trabajo</h3></div>
                        <div class="form-grid">
                            <div class="form-group"><label>Salario bruto anual</label><input type="number" id="trabSalarioBruto" class="form-input" value="0" step="0.01" onchange="calculateTrabajo()"></div>
                            <div class="form-group"><label>Retención empresa (%)</label><input type="number" id="trabRetencion" class="form-input" value="0" step="0.01" onchange="calculateTrabajo()"></div>
                            <div class="form-group"><label>Cuota Seguridad Social</label><input type="number" id="trabSS" class="form-input" value="0" step="0.01" onchange="calculateTrabajo()"></div>
                            <div class="form-group"><label>Dietas exentas</label><input type="number" id="trabDietas" class="form-input" value="0" step="0.01" onchange="calculateTrabajo()"></div>
                            <div class="form-group"><label>Cuota sindicato</label><input type="number" id="trabSindicato" class="form-input" value="0" step="0.01" onchange="calculateTrabajo()"></div>
                            <div class="form-group"><label>Otros gastos deducibles</label><input type="number" id="trabOtros" class="form-input" value="0" step="0.01" onchange="calculateTrabajo()"></div>
                        </div>
                        <div id="trabajoResult" class="trabajo-result"></div>
                    </div>
                </div>
                <div id="fiscalMinimos" class="fiscal-panel">
                    <div class="card">
                        <div class="card-header"><h3>Mínimos Personales y Familiares</h3></div>
                        <div class="form-grid">
                            <div class="form-group"><label>Edad contribuyente</label><input type="number" id="minEdad" class="form-input" value="35" onchange="calculateMinimos()"></div>
                            <div class="form-group"><label>Discapacidad contribuyente (%)</label><input type="number" id="minDiscapacidad" class="form-input" value="0" onchange="calculateMinimos()"></div>
                        </div>
                        <div class="minimos-section">
                            <h4>Hijos <button class="btn-sm" onclick="addHijo()">+ Añadir</button></h4>
                            <div id="hijosList" class="hijos-list"></div>
                        </div>
                        <div class="minimos-section">
                            <h4>Ascendientes <button class="btn-sm" onclick="addAscendiente()">+ Añadir</button></h4>
                            <div id="ascendientesList" class="ascendientes-list"></div>
                        </div>
                        <div id="minimosResult" class="minimos-result"></div>
                    </div>
                </div>
                <div id="fiscalResumen" class="fiscal-panel">
                    <div class="card">
                        <div class="card-header"><h3>Resumen IRPF</h3></div>
                        <div id="irpfResumen" class="irpf-resumen"></div>
                    </div>
                </div>
            </section>
            <section id="simulator" class="section">
                <div class="card">
                    <div class="card-header"><h3>Simulador de Interés Compuesto</h3></div>
                    <div class="simulator-form">
                        <div class="form-grid">
